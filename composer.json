{
    "name": "rh/backup",
    "description": "DB-Backup-Plugin der rh-blueprint Kollektion. Export, Import, Restore. Pure PHP, Shared-Hosting-tauglich.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Robin Herbeck",
            "homepage": "https://robinherbeck.de"
        }
    ],
    "require": {
        "php": ">=8.1",
        "rh/blueprint-core": "^2.0",
        "rh/db-engine": "^1.0",
        "yahnis-elsts/plugin-update-checker": "^5.5"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/herbeckrobin/rh-blueprint-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/herbeckrobin/rh-db-engine"
        }
    ],
    "autoload": {
        "psr-4": {
            "RhBackup\\": "inc/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
